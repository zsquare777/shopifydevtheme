<div class="announcement-slider">
  {% for block in section.blocks %}
    <a href="{{ block.settings.link }}" class="announcement-item">
      {% if block.settings.icon %}
        <img
          src="{{ block.settings.icon | image_url: width: 50 }}"
          alt=""
          width="20"
          height="20">
      {% endif %}

      <span>{{ block.settings.text }}</span>
    </a>
  {% endfor %}
</div>

<style>
.announcement-slider{
  background:#000;
  color:#fff;
  display:flex;
  justify-content:center;
  gap:40px;
  padding:10px;
}

.announcement-item{
  display:flex;
  align-items:center;
  gap:8px;
  color:#fff;
  text-decoration:none;
}

.announcement-item img{
  width:20px;
  height:20px;
}
</style>

{% schema %}
{
  "name": "Announcement Slider",
  "blocks": [
    {
      "type": "item",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Slider"
    }
  ]
}
{% endschema %}