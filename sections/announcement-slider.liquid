<div class="announcement-slider">
  <div class="announcement-track">

    {% for i in (1..2) %}
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="announcement-item">
          {% if block.settings.icon %}
            <img
              src="{{ block.settings.icon | image_url: width: 50 }}"
              alt=""
              width="20"
              height="20">
          {% endif %}

          <span>{{ block.settings.text }}</span>
        </a>
      {% endfor %}
    {% endfor %}

  </div>
</div>

<style>
.announcement-slider:hover .announcement-track{
  animation-play-state: paused;
}

.announcement-item{
  position:relative;
}

.announcement-item span::after{
  content:"";
  position:absolute;
  left:0;
  bottom:-3px;
  width:0%;
  height:2px;
  background:#fff;
  transition:width 0.3s ease;
}

.announcement-item:hover span::after{
  width:100%;
}
</style>

{% schema %}
{
  "name": "Announcement Slider",
  "blocks": [
    {
      "type": "item",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Shipping"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Slider"
    }
  ]
}
{% endschema %}

