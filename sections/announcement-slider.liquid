<div class="announcement-slider">
  <div class="announcement-slider__wrapper">
    {% for block in section.blocks %}
      <a
        href="{{ block.settings.link }}"
        class="announcement-slider__item"
        {{ block.shopify_attributes }}
      >
        {% if block.settings.icon != blank %}
          <img
            src="{{ block.settings.icon | image_url: width: 60 }}"
            alt="{{ block.settings.text }}"
            width="24"
            height="24"
          >
        {% endif %}

        <span>{{ block.settings.text }}</span>
      </a>
    {% endfor %}
  </div>
</div>

<style>
.announcement-slider{
  background:#000;
  padding:10px 0;
  overflow-x:auto;
}

.announcement-slider__wrapper{
  display:flex;
  justify-content:center;
  align-items:center;
  gap:40px;
  min-width:max-content;
}

.announcement-slider__item{
  display:flex;
  align-items:center;
  gap:8px;
  text-decoration:none;
  color:#fff;
  font-size:14px;
  font-weight:600;
}

.announcement-slider__item img{
  width:20px;
  height:20px;
  object-fit:contain;
}

@media(max-width:768px){
  .announcement-slider__wrapper{
    gap:20px;
    padding:0 10px;
  }

  .announcement-slider__item{
    font-size:12px;
  }
}
</style>

{% schema %}
{
  "name": "Announcement Slider",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Shipping"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Slider"
    }
  ]
}
{% endschema %}